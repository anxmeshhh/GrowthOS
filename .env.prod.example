# .env.prod — copy to backend/.env.prod and fill in real values.
# NEVER commit the real .env.prod to git.
# Generate a new SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(50))"

# Django
DEBUG=False
SECRET_KEY=generate_a_very_secure_random_string_here
ALLOWED_HOSTS=growth-os.tech,www.growth-os.tech,api.growth-os.tech

# MySQL Database
MYSQL_DATABASE=growthos_prod
MYSQL_USER=growthos_user
MYSQL_PASSWORD=secure_database_password_here
MYSQL_ROOT_PASSWORD=secure_root_password_here
MYSQL_HOST=db
MYSQL_PORT=3306

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Frontend build-time public OAuth client IDs (baked into the SPA by Vite).
# These are PUBLIC client IDs (safe to expose) — NOT the secrets above.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GITHUB_CLIENT_ID=your_github_client_id

# Optional: extra CORS origins (comma-separated). Defaults cover the apex + www.
# CORS_ALLOWED_ORIGINS=https://growth-os.tech,https://www.growth-os.tech

# API Keys
GROQ_API_KEY=your_groq_key
GEMINI_API_KEY=your_gemini_key  # only needed for offline import_roadmaps command

# Encryption (for GitHub access tokens stored in DB)
FERNET_KEY=generate_with_python_cryptography_fernet_generate_key

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=GrowthOS <your_email@gmail.com>
